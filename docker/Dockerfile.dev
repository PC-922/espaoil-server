FROM --platform=linux/amd64 gradle:7-jdk17-alpine AS gradle-base
WORKDIR /app
# Cache gradle deps layer
COPY settings.gradle.kts /app/
COPY app/build.gradle.kts /app/app/
COPY gradle/ /app/gradle/
RUN gradle dependencies --no-daemon 2>&1 | tail -3

FROM gradle-base AS dev
COPY . .
COPY docker/entrypoint-dev.sh /app/entrypoint-dev.sh
RUN chmod +x /app/entrypoint-dev.sh

EXPOSE 8080 5005
# Live reload entrypoint — watches src changes, rebuilds + restarts
ENTRYPOINT ["/app/entrypoint-dev.sh"]
